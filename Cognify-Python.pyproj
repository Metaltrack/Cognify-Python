    </Compile>
    <Compile Include="Level 1\TempConversion.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="Level 2\GuesserGame1.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="Level 2\GuesserGame2.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="Level 2\PasswordStrength.py">
      <SubType>Code</SubType>
    </Compile>
  </ItemGroup>
  <ItemGroup>
    <Folder Include="Level 1\" />
    <Folder Include="Level 2\" />
  </ItemGroup>
  <Import Project="$(MSBuildExtensionsPath32)\Microsoft\VisualStudio\v$(VisualStudioVersion)\Python Tools\Microsoft.PythonTools.targets" />
